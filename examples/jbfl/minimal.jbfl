.*.nodes[*][*] {
    PadDecimals: 3;
}

.*.nodes, .*.beams, .*.triangles {
    AutoPad: true;
}

.*.nodes {
    AlignObjectKeys: true;
}

.*.nodes[*], .*.flexbodies[*],
.*.beams[*], .*.triangles[*],
.*.variables[*], .*.glowMap.*,
.*.rails.*, .*.props[*],
.*.slots[*], .*.slots2[*],
.*.controller[*], .*.components.electrics.smoothers[*],
.*.mainEngine.torque[*], .*.mainEngine.burnEfficiency[*],
.*.powertrain[*] {
    NoComplexNewLine : true;
    PreserveNumberFormat : true;
}

.*.sounds, .*.soundConfig, .*.soundConfigExhaust,
.*.information {
    ForceComplexNewLine: true;
    AlignObjectKeys: true;
}

.*.glowMap {
    AlignObjectKeys: true;
    AutoPadSubObjects: true;
}
